/* 微信小程序全局样式 - app.wxss */
page {
  background: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 14px;
  color: #333;
}

.app-logo {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #f27835, #e8553e);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28px;
  font-weight: 800;
}

.btn-primary {
  background: linear-gradient(135deg, #f27835, #e8553e);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
}

.card {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
