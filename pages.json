        "navigationBarTitleText": "AI 智能入库"
      }
    },
    {
      "path": "pages/customers/list",
      "style": {
        "navigationBarTitleText": "客户管理"
      }
    },
    {
      "path": "pages/orders/list",
      "style": {
        "navigationBarTitleText": "订单管理"
      }
    },
    {
      "path": "pages/ai/dashboard",
      "style": {
        "navigationBarTitleText": "AI 分析面板"
      }
