  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "衫云智管",
    "navigationBarBackgroundColor": "#f27835",
    "backgroundColor": "#f5f5f7",
    "app-plus": {
      "background": "#f5f5f7"
    }
